// Internal Macros
// ^^^^^^

#define __trait_predicate_c(__type, __name, ...)                                                   \
    template <class T> struct __name : integral_constant<__type, __VA_ARGS__> {                    \
    };                                                                                             \
    template <class T> constexpr __type __name##_v = __name<T>::value

#define __trait_predicate_cc(__type, __name, ...)                                                  \
    template <class T, class U> struct __name : integral_constant<__type, __VA_ARGS__> {           \
    };                                                                                             \
    template <class T, class U> constexpr __type __name##_v = __name<T, U>::value

#define __trait_predicate_cu(__type, __name, ...)                                                  \
    template <class T, unsigned N = 0> struct __name : integral_constant<__type, __VA_ARGS__> {    \
    };                                                                                             \
    template <class T, unsigned N = 0> constexpr __type __name##_v = __name<T, N>::value

#define __trait_predicate_ccv(__type, __name, ...)                                                 \
    template <class T, class... Args> struct __name : integral_constant<__type, __VA_ARGS__> {     \
    };                                                                                             \
    template <class T, class... Args> constexpr __type __name##_v = __name<T, Args...>::value

#define __trait_identity(__name)                                                                   \
    template <class T> struct __name {                                                             \
        using type = T;                                                                            \
    };                                                                                             \
    template <class T> using __name##_t = typename __name<T>::type

#define __trait_expression(__name, ...)                                                            \
    template <class T> struct __name {                                                             \
        using type = __VA_ARGS__;                                                                  \
    };                                                                                             \
    template <class T> using __name##_t = typename __name<T>::type

#define __trait_custom_expression(__name, __expression, ...)                                       \
    struct __name __VA_ARGS__ {                                                                    \
        using type = __expression;                                                                 \
    }

#define __trait_transform_expression(__name, __expression, ...)                                    \
    template <class T> __trait_custom_expression(__name, __expression, __VA_ARGS__)

#define __trait_transform(__name, ...) __trait_transform_expression(__name, T, __VA_ARGS__)

// Helper Classes
// ^^^^^^

template <class T, T v> struct integral_constant {
    static constexpr T value = v;
    using value_type         = T;
    using type               = integral_constant<T, v>;

    constexpr operator value_type() const noexcept { return value; }
};

template <bool B> using bool_constant = integral_constant<bool, B>;
using true_type                       = bool_constant<true>;
using false_type                      = bool_constant<false>;

