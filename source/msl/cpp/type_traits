template <class Fn, class... Args>
concept __is_invocable =
    requires(Fn fn, Args&&... args) { __builtin_invoke(fn, static_cast<Args&&>(args)...); };

template <class R, class Fn, class... Args>
concept __is_invocable_r = requires(Fn fn, Args&&... args) {
    __builtin_invoke(fn, static_cast<Args&&>(args)...);
    requires __is_convertible(decltype(__builtin_invoke(fn, static_cast<Args&&>(args)...)), R);
};

template <class Fn, class... Args>
concept __is_nothrow_invocable = requires(Fn fn, Args&&... args) {
    __builtin_invoke(fn, static_cast<Args&&>(args)...);
    requires noexcept(__builtin_invoke(fn, static_cast<Args&&>(args)...));
};

template <class R, class Fn, class... Args>
concept __is_nothrow_invocable_r = requires(Fn fn, Args&&... args) {
    __builtin_invoke(fn, static_cast<Args&&>(args)...);
    requires noexcept(__builtin_invoke(fn, static_cast<Args&&>(args)...));
    requires __is_convertible(decltype(__builtin_invoke(fn, static_cast<Args&&>(args)...)), R);
};

template <class Fn, class... Args>
struct is_invocable : integral_constant<bool, __is_invocable<Fn, Args...>> {
};
template <class Fn, class... Args> constexpr bool is_invocable_v = is_invocable<Fn, Args...>::value;

template <class R, class Fn, class... Args>
struct is_invocable_r : integral_constant<bool, __is_invocable_r<R, Fn, Args...>> {
};
template <class R, class Fn, class... Args>
constexpr bool is_invocable_r_v = is_invocable_r<R, Fn, Args...>::value;

template <class Fn, class... Args>
struct is_nothrow_invocable : integral_constant<bool, __is_nothrow_invocable<Fn, Args...>> {
};
template <class Fn, class... Args>
constexpr bool is_nothrow_invocable_v = is_nothrow_invocable<Fn, Args...>::value;

template <class R, class Fn, class... Args>
struct is_nothrow_invocable_r : integral_constant<bool, __is_nothrow_invocable_r<R, Fn, Args...>> {
};
template <class R, class Fn, class... Args>
constexpr bool is_nothrow_invocable_r_v = is_nothrow_invocable_r<R, Fn, Args...>::value;

