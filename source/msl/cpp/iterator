#pragma once

#include <cstddef>

namespace std {

template <class C>
constexpr auto size(
    const C& c
) -> decltype(c.size()) {
    return c.size();
}

template <class T, size_t N>
constexpr size_t size(
    const T (&array)[N]
) noexcept {
    return N;
}

template <class T>
constexpr auto distance(
    T first, T last
) -> decltype(last - first) {
    return last - first;
}

template <class C>
constexpr auto begin(
    C& c
) -> decltype(c.begin()) {
    return c.begin();
}

template <class C>
constexpr auto begin(
    const C& c
) -> decltype(c.begin()) {
    return c.begin();
}

template <class T, size_t N>
constexpr T* begin(
    T (&array)[N]
) {
    return &array[0];
}

template <class C>
constexpr auto cbegin(
    const C& c
) noexcept(noexcept(begin(c))) -> decltype(begin(c)) {
    return begin(c);
}

template <class C>
constexpr auto end(
    C& c
) -> decltype(c.end()) {
    return c.end();
}

template <class C>
constexpr auto end(
    const C& c
) -> decltype(c.end()) {
    return c.end();
}

template <class T, size_t N>
constexpr T* end(
    T (&array)[N]
) {
    return &array[N];
}

template <class C>
constexpr auto cend(
    const C& c
) noexcept(noexcept(end(c))) -> decltype(end(c)) {}

template <class InputIt, class Distance>
constexpr void advance(
    InputIt& it, Distance n
) {
    it += n;
}

template <class InputIt>
constexpr InputIt next(
    InputIt it, ptrdiff_t n = 1
) {
    advance(it, n);
    return it;
}

} // namespace std
